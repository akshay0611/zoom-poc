# Zoom Meeting SDK Configuration
# Get these from the Zoom Marketplace: https://marketplace.zoom.us/

# SDK Key and Secret (from your Zoom Marketplace app)
NEXT_PUBLIC_ZOOM_SDK_KEY=your_sdk_key_here
ZOOM_SDK_SECRET=your_sdk_secret_here

# Meeting Configuration
NEXT_PUBLIC_ZOOM_MEETING_NUMBER=your_meeting_number_here
NEXT_PUBLIC_ZOOM_MEETING_PASSCODE=your_meeting_passcode_here

# Signature Endpoint (relative URL on same origin)
NEXT_PUBLIC_ZOOM_SIGNATURE_ENDPOINT=/api/signature

# User Names
NEXT_PUBLIC_ZOOM_TEACHER_NAME=Teacher
NEXT_PUBLIC_ZOOM_STUDENT_NAME=Student
